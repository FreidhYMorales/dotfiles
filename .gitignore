# ── Sensitive — never commit ──────────────────────────────────────────────────
backup/backups/
dotfiles/zsh/.config/zsh/secrets.zsh

# ── Symlink — tracked via dotfiles/quickshell instead ────────────────────────
backup/quickshell

# ── Large binaries in archive — not useful in git ────────────────────────────
backup/archive/restorations/grub/

# ── External plugins — cloned by bootstrap, not tracked here ─────────────────
dotfiles/yazi/.config/yazi/plugins/fg.yazi/
backup/yazi/plugins/fg.yazi/

# ── Runtime-generated by sddm-theme-sync / matugen ───────────────────────────
system/sddm/themes/silent/configs/custom.conf
system/sddm/themes/silent/backgrounds/qs-current.*

# ── Tool cache / local settings ──────────────────────────────────────────────
**/.atl/*.cache.json
**/.claude/settings.local.json
.config

# ── System-specific archive data — not dotfiles ───────────────────────────────
backup/archive/restorations/probe-os/
backup/archive/mysql/

# ── Browser profile — personal data, binary files ────────────────────────────
backup/zen/profile/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~
*.swp
*.swo
