#!/bin/bash
# Línea de estado completa de batería para notificaciones o waybar tooltip.
# Output: "󰁹    Battery 85%  ·  2h 15m left  ·  12.5W / 80Wh"
battery_info=$(upower -i "$(upower -e | grep BAT)")

percentage=$(echo "$battery_info" | awk '/percentage/ { print int($2); exit }')
power_rate=$(echo  "$battery_info" | awk '/energy-rate/ {
    rounded = sprintf("%.1f", $2); sub(/\.0$/, "", rounded); print rounded; exit }')
capacity=$(echo    "$battery_info" | awk '/energy-full:/ { print $2; exit }')
state=$(echo       "$battery_info" | awk '/state/ { print $2; exit }')
time=$(battery-time)

if [[ $state == "charging" ]]; then
    echo "󰁹    Battery ${percentage}%  ·  ${time} to full  ·   ${power_rate}W / ${capacity}Wh"
else
    echo "󰁹    Battery ${percentage}%  ·  ${time} left  ·   ${power_rate}W / ${capacity}Wh"
fi
