#!/bin/bash
# Set lightweight desktop notification reminders via systemd user timers.
# Usage:
#   reminder <minutes> [message]   — set a reminder
#   reminder show                  — list active reminders
#   reminder clear                 — cancel all reminders
#
# Deps: systemd (user session), notify-send, notification-send (sibling script)

set -euo pipefail

REMINDER_DIR="${XDG_RUNTIME_DIR:-/tmp}/reminders"
UNIT_PREFIX="reminder"

format_remaining() {
  local seconds=$1
  local minutes=$((seconds / 60))
  local remainder=$((seconds % 60))

  if ((minutes > 0 && remainder > 0)); then echo "${minutes}m ${remainder}s"
  elif ((minutes > 0));               then echo "${minutes}m"
  else                                     echo "${remainder}s"
  fi
}

parse_systemd_timespan() {
  local timespan="$1" total=0 value unit whole
  while read -r value unit; do
    whole=${value%.*}
    case $unit in
      d)   total=$((total + whole * 86400)) ;;
      h)   total=$((total + whole * 3600))  ;;
      min) total=$((total + whole * 60))    ;;
      s)   total=$((total + whole))         ;;
    esac
  done < <(grep -oE '[0-9]+([.][0-9]+)?(d|h|min|s|ms|us)' <<<"$timespan" \
           | sed -E 's/^([0-9.]+)([a-z]+)$/\1 \2/')
  echo "$total"
}

show_reminders() {
  local timers body="" uptime timer next next_seconds remaining reminder_message

  timers=$(systemctl --user list-timers --all --no-legend --no-pager \
    "${UNIT_PREFIX}-*.timer" 2>/dev/null | awk '{ print $(NF - 1) }')
  uptime=$(awk '{ print int($1) }' /proc/uptime)

  for timer in $timers; do
    next=$(systemctl --user show -P NextElapseUSecMonotonic "$timer" 2>/dev/null || true)
    [[ -z $next ]] && continue

    next_seconds=$(parse_systemd_timespan "$next")
    ((next_seconds <= uptime)) && continue

    remaining=$((next_seconds - uptime))
    reminder=${timer%.timer}
    reminder=${reminder#${UNIT_PREFIX}-}
    set_at=${reminder##*-}
    reminder_minutes=${reminder%%m-*}
    reminder_message=""
    [[ -f $REMINDER_DIR/${timer%.timer}.message ]] \
      && reminder_message=$(<"$REMINDER_DIR/${timer%.timer}.message")

    if [[ -n $reminder_message ]]; then
      body+="$reminder_message in $(format_remaining $remaining) ($(date -d "@$((set_at + reminder_minutes * 60))" +%-H:%M))"$'\n'
    else
      body+="${reminder_minutes}-min reminder in $(format_remaining $remaining) ($(date -d "@$((set_at + reminder_minutes * 60))" +%-H:%M))"$'\n'
    fi
  done

  if [[ -z $body ]]; then
    notification-send "󰔛" "Upcoming reminders" "No outstanding reminders" -u low
  else
    notification-send "󰔛" "Upcoming reminders" "${body%$'\n'}" -u low
  fi
}

clear_reminders() {
  local units
  units=$(systemctl --user list-timers --all --no-legend --no-pager \
    "${UNIT_PREFIX}-*.timer" 2>/dev/null | awk '{ print $(NF - 1), $NF }')

  [[ -n $units ]] && xargs -r systemctl --user stop <<<"$units" || true
  rm -f "$REMINDER_DIR"/${UNIT_PREFIX}-*.message 2>/dev/null || true
  notification-send "󰔛" "All reminders have been cleared" -u low
}

case ${1:-} in
  show|list) show_reminders; exit 0 ;;
  clear)     clear_reminders; exit 0 ;;
esac

minutes=${1:-}
shift || true
message="$*"

if [[ -z $minutes || ! $minutes =~ ^[0-9]+$ ]] || ((minutes == 0)); then
  echo "Usage: reminder <minutes> [message]"
  echo "       reminder show"
  echo "       reminder clear"
  exit 1
fi

[[ -z $message ]] && message="Your ${minutes} minutes are up"

set_at=$(date +%s)
remind_at=$(date -d "+${minutes} minutes" +%H:%M)
unit="${UNIT_PREFIX}-${minutes}m-${set_at}"
message_file="$REMINDER_DIR/$unit.message"

mkdir -p "$REMINDER_DIR"
[[ -n $message ]] && printf "%s" "$message" >"$message_file"

systemd-run --user --quiet --collect --on-active="${minutes}m" --unit="$unit" \
  bash -c 'notification-send "󰔛" "Reminder" "$1" -u critical; rm -f "$2"' \
  bash "$message" "$message_file"

if [[ $message != "Your ${minutes} minutes are up" ]]; then
  notification-send "󰔛" "$message in ${minutes} minutes" "You'll be reminded at $remind_at" -u low
else
  notification-send "󰔛" "Reminder set for ${minutes} minutes" "You'll be reminded at $remind_at" -u low
fi
